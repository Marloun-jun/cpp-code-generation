# ======================================================================
# .gitignore - Корневой файл для всего проекта NS
# ======================================================================

# ======================================================================
# Виртуальное окружение Python
# ======================================================================
.venv/
env/
venv/
ENV/
*.egg-info/

# ======================================================================
# Настройки VS Code и IDE
# ======================================================================
.vscode/
.vscode-server/
.idea/
*.swp
*.swo
*~

# ======================================================================
# Кэш Python (везде)
# ======================================================================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.coverage
**/.mypy_cache/
**/.ruff_cache/
**/.ipynb_checkpoints/

# ======================================================================
# Сборка C++ (для BPE токенизатора) - ВСЕ build директории
# ======================================================================
**/build/
**/build_*/
**/_deps/
**/CMakeCache.txt
**/CMakeFiles/
**/Makefile
**/cmake_install.cmake
**/CTestTestfile.cmake
**/*.cmake
**/compile_commands.json

# ======================================================================
# Скомпилированные бинарные файлы
# ======================================================================
**/*.o
**/*.obj
**/*.exe
**/*.so
**/*.so.*
**/*.dylib
**/*.a
**/*.lib
**/*.dll
**/*.bin
**/*.out

# ======================================================================
# Модели и большие бинарные данные (ИГНОРИРУЕМ - слишком большие для Git)
# ======================================================================
**/*.ckpt
**/*.npy
**/*.npz
**/*.h5
**/*.hdf5
**/*.pkl
**/*.pickle
**/*.pth
**/*.pt
**/*.onnx
**/*.pb
**/*.tflite
**/*.bin
**/*.model

# ======================================================================
# Версионные копии (не нужно хранить в git)
# ======================================================================
**_versions/
**/backup/
**/old/
**/archive/
**/*_backup/
**/*_old/

# ======================================================================
# Временные файлы
# ======================================================================
**/*.tmp
**/*.temp
**/*.bak
.DS_Store
Thumbs.db
*.lock
*.pid

# ======================================================================
# Отчеты и результаты
# ======================================================================
**/reports/
**/*.log
**/*.prof
**/perf.data*
**/callgrind.out*
**/gmon.out
**/*.svg
**/*.png
**/*.jpg
**/*.pdf
**/benchmark_results.json
**/profile_results.json
**/test_results.json

# ======================================================================
# Данные (кроме корпусов кода)
# ======================================================================
**/*.csv
!3_my_cpp_nn_project/cpp_code_model/data/corpus/*.txt
!3_my_cpp_nn_project/cpp_code_model/data/*.jsonl
!3_my_cpp_nn_project/bpe_tokenizer_cpu/bpe_cpp/benchmarks/bench_data/*.txt
**/data/raw/
**/data/tokenized/

# ======================================================================
# Docker образы и файлы
# ======================================================================
*.tar
*.tar.gz
*.tar.xz
*.tar.bz2
*.docker-image
docker-images/
*.dockerignore.tmp

# ======================================================================
# Файлы конфигурации с секретами
# ======================================================================
.env
.env.local
.env.*.local
*.secret
secrets/
**/config.local.*
**/*_secret.*

# ======================================================================
# Jupyter ноутбуки (если есть)
# ======================================================================
**/.ipynb_checkpoints/
**/*.ipynb

# ======================================================================
# macOS
# ======================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# ======================================================================
# Linux
# ======================================================================
.directory
*.desktop

# ======================================================================
# Windows
# ======================================================================
Thumbs.db
ehthumbs.db
Desktop.ini