# ======================================================================
# .gitignore - Корневой файл для всего проекта NS
# ======================================================================

# ======================================================================
# Виртуальное окружение Python
# ======================================================================
.venv/
env/
venv/
ENV/
*.egg-info/

# ======================================================================
# Настройки VS Code
# ======================================================================
.vscode/
.vscode-server/

# ======================================================================
# Кэш Python (везде)
# ======================================================================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.coverage
**/.mypy_cache/
**/.ruff_cache/
**/.ipynb_checkpoints/

# ======================================================================
# Сборка C++ (для BPE токенизатора)
# ======================================================================
3_my_cpp_nn_project/cpp-bpe-tokenizer/bpe_cpp/build/
3_my_cpp_nn_project/cpp-bpe-tokenizer/bpe_cpp/_deps/
3_my_cpp_nn_project/cpp-bpe-tokenizer/bpe_cpp/CMakeCache.txt
3_my_cpp_nn_project/cpp-bpe-tokenizer/bpe_cpp/CMakeFiles/
**/*.o
**/*.obj
**/*.exe
**/*.so
**/*.dylib
**/*.a
**/*.lib

# ======================================================================
# Бинарные данные и модели (ИГНОРИРУЕМ!)
# ======================================================================
**/*.npy
**/*.npz
**/*.h5
**/*.hdf5
**/*.pkl
**/*.pickle
**/*.pth
**/*.pt
**/*.onnx
**/*.bin
**/*.pb
**/*.tflite

# ======================================================================
# Версионные копии (не нужно хранить в git)
# ======================================================================
**_versions/
**/backup/
**/old/
**/archive/

# ======================================================================
# Временные файлы
# ======================================================================
**/*.tmp
**/*.temp
**/*.bak
**/*.swp
**/*.swo
*~
.DS_Store
Thumbs.db

# ======================================================================
# Отчеты и результаты
# ======================================================================
**/reports/
**/*.log
**/*.prof
**/perf.data*
**/callgrind.out*
**/gmon.out
**/*.svg
**/*.png
**/*.jpg
**/*.pdf
**/benchmark_results.json
**/profile_results.json

# ======================================================================
# CSV файлы - выборочно
# ======================================================================
# Игнорируем все CSV, кроме нужных
**/*.csv
!3_my_cpp_nn_project/cpp-bpe-tokenizer/bpe_cpp/benchmarks/bench_data/sample_code.txt

# ======================================================================
# Docker образы (большие файлы)
# ======================================================================
*.tar
*.tar.gz
*.tar.xz
*.tar.bz2
docker-images/
*.docker-image