def validate_cpp_csv_correctly(filename):
    """
    КОРРЕКТНАЯ проверка CSV файла с C++ кодом.
    Использует правильные настройки для csv.reader()
    """
    
    csv.register_dialect('cppcsv', CppCsvDialect)
    
    print("=" * 70)
    print("КОРРЕКТНАЯ ПРОВЕРКА CSV ФАЙЛА")
    print("=" * 70)
    
    with open(filename, 'r', encoding='utf-8') as f:
        reader = csv.reader(f, dialect='cppcsv')
        
        headers = next(reader)
        print(f"Заголовки: {headers}")
        
        data_rows = 0
        correct_rows = 0
        problematic_rows = []
        
        for i, row in enumerate(reader, start=2):
            # Пропускаем комментарии
            if not row or not row[0].strip():
                continue
            
            if row[0].strip().startswith('#'):
                continue
            
            data_rows += 1
            
            if len(row) > 1:
                code = row[1]
                
                # Проверяем только строки с cout
                if 'cout' in code:
                    # Ищем оператор <<
                    if '<<' in code:
                        pos = code.find('<<')
                        after_op = code[pos+2:pos+30].lstrip()
                        
                        # ПРАВИЛЬНАЯ проверка:
                        # После << должна быть кавычка (экранированная или нет)
                        if after_op.startswith('"') or after_op.startswith('\\\\"'):
                            correct_rows += 1
                        else:
                            problematic_rows.append((i, after_op[:20], row[0][:50]))
            
            # Показываем первые 3 строки
            if data_rows <= 3:
                print(f"\\nСтрока {i}:")
                print(f"  Описание: {row[0][:50]}...")
                print(f"  Код: {code[:80]}...")
                
                if '<<' in code:
                    pos = code.find('<<')
                    after = code[pos+2:pos+30].lstrip()
                    print(f"  После '<<': {repr(after[:15])}")
                    
                    if after.startswith('"') or after.startswith('\\\\"'):
                        print(f"  ✓ Корректно")
                    else:
                        print(f"  ⚠️  Проблема")
    
    print(f"\\n" + "="*70)
    print(f"РЕЗУЛЬТАТЫ:")
    print(f"Всего строк с данными: {data_rows}")
    print(f"Корректных строк с cout: {correct_rows}")
    print(f"Проблемных строк: {len(problematic_rows)}")
    
    if problematic_rows:
        print(f"\\nПервые 5 проблемных строк:")
        for line_num, after_op, description in problematic_rows[:5]:
            print(f"  Строка {line_num}: после << идет '{after_op}' - '{description}...'")
    else:
        print(f"\\n✓ Все строки корректны!")
    
    return len(problematic_rows) == 0

